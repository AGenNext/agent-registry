{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agennext.dev/schemas/did-document.schema.json",
  "title": "DID Document",
  "type": "object",
  "required": ["@context", "id", "verificationMethod"],
  "properties": {
    "@context": {
      "oneOf": [
        { "type": "string", "format": "uri" },
        { "type": "array", "items": { "oneOf": [{ "type": "string" }, { "type": "object" }] } }
      ]
    },
    "id": { "type": "string", "pattern": "^did:[a-z0-9]+:[A-Za-z0-9._:%-]+" },
    "controller": {
      "oneOf": [
        { "type": "string", "pattern": "^did:" },
        { "type": "array", "items": { "type": "string", "pattern": "^did:" } }
      ]
    },
    "verificationMethod": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "controller"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "controller": { "type": "string", "pattern": "^did:" },
          "publicKeyJwk": { "type": "object" },
          "publicKeyMultibase": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "authentication": { "type": "array", "items": { "oneOf": [{ "type": "string" }, { "type": "object" }] } },
    "assertionMethod": { "type": "array", "items": { "oneOf": [{ "type": "string" }, { "type": "object" }] } },
    "service": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": true
}
